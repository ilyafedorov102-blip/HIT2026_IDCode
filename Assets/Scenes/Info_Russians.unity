    - 2 \u0448\u0442.\r\n\u0440\u0430\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043C\u0430\u0441\u043B\u043E - 2 \u0441\u0442. \u043B.\r\n\u0434\u0443\u0448\u0438\u0441\u0442\u044B\u0439
    \u043F\u0435\u0440\u0435\u0446 - 3 \u0448\u0442.\r\n\u0447\u0451\u0440\u043D\u044B\u0439
