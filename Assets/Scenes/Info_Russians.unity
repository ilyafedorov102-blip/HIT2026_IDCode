  m_text: "\u0420\u0435\u0446\u0435\u043F\u0442 \u0449\u0435\u0439:\n\u0433\u043E\u0432\u044F\u0434\u0438\u043D\u0430
    \u043D\u0430 \u043A\u043E\u0441\u0442\u043E\u0447\u043A\u0435 - 500 \u0433\r\n\u043A\u0430\u043F\u0443\u0441\u0442\u0430
    \u0431\u0435\u043B\u043E\u043A\u043E\u0447\u0430\u043D\u043D\u0430\u044F - 200
    \u0433\r\n\u043A\u0430\u0440\u0442\u043E\u0444\u0435\u043B\u044C - 3 \u0448\u0442.\r\n\u043B\u0443\u043A
    - 1 \u0448\u0442.\r\n\u043C\u043E\u0440\u043A\u043E\u0432\u044C - 2 \u0448\u0442.\r\n\u043F\u043E\u043C\u0438\u0434\u043E\u0440\u044B
    - 1 \u0448\u0442.\r\n\u043F\u0435\u0442\u0440\u0443\u0448\u043A\u0430 - 20 \u0433\r\n\u0443\u043A\u0440\u043E\u043F
