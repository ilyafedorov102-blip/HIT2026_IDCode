  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0420\u0443\u0441\u0441\u043A\u0438\u0435 - \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0441\u043B\u0430\u0432\u044F\u043D\u0441\u043A\u0438\u0439
    \u043D\u0430\u0440\u043E\u0434, \u0441\u0430\u043C\u044B\u0439 \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0439
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438 \u0438 \u0415\u0432\u0440\u043E\u043F\u0435.
    \u0427\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u044C - \u043E\u043A\u043E\u043B\u043E
    134 \u043C\u043B\u043D \u0447\u0435\u043B\u043E\u0432\u0435\u043A.\r\n\u0421\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0441\u043B\u0430\u0432\u044F\u043D\u0441\u043A\u0438\u0445
    \u043F\u043B\u0435\u043C\u0451\u043D \u0432 XI\u2013XII \u0432\u0435\u043A\u0430\u0445.\r\n\u0420\u043E\u0434\u043D\u043E\u0439
    \u044F\u0437\u044B\u043A - \u0440\u0443\u0441\u0441\u043A\u0438\u0439. \u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u0445 - \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u044B\u0435
    \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0435.\n\u041E\u0434\u043D\u043E
    \u0438\u0437 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0431\u043B\u044E\u0434 - \u0449\u0438."
